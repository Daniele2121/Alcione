platform :ios, '15.0'

# Questa riga è fondamentale per caricare i plugin Flutter
podhelper_path = File.join(File.dirname(File.realpath(__FILE__)), 'Flutter', 'podhelper.rb')
require podhelper_path

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      # Forza la versione target su tutti i pod per evitare conflitti
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'

      # Risolve l'errore "Module not found" forzando la ricerca dei moduli
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      config.build_settings['DEFINES_MODULE'] = 'YES'

      # Opzionale: Disabilita il bitcode (ormai deprecato da Apple)
      config.build_settings['ENABLE_BITCODE'] = 'NO'
    end
  end
end