# Podfile per Alcione Scouting - Versione definitiva
platform :ios, '15.0'

# Percorso necessario per collegare Flutter
# Non toccare queste due righe
flutter_ios_podfile_setup = File.join(File.dirname(File.realpath(__FILE__)), '.symlinks', 'plugins', 'flutter_plugin_loader', 'ios', 'podhelper.rb')
if File.exist?(flutter_ios_podfile_setup)
  require flutter_ios_podfile_setup
else
  # Se il file sopra non esiste, usiamo il fallback ufficiale
  podhelper_path = File.join(File.dirname(File.realpath(__FILE__)), 'Flutter', 'podhelper.rb')
  require podhelper_path if File.exist?(podhelper_path)
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Installa i plugin di Flutter
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Forza iOS 15 su tutto per Firestore
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end
  end
end