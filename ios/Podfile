platform :ios, '15.0'

# 1. Percorso esplicito verso l'helper di Flutter
require File.expand_path(File.join('..', 'Flutter', 'podhelper.rb'), __FILE__)

# 2. Definizione dei target di build
project 'Runner', {
  'Debug' => :debug,
  'Release' => :release,
  'Profile' => :profile,
}

target 'Runner' do
  # Fondamentale per i plugin moderni
  use_frameworks! :linkage => :static
  use_modular_headers!

  # 3. Questo comando DEVE installare i plugin
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

# 4. Logica di post-installazione per correggere gli errori di Xcode
post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      # Risolve conflitti di versioni e architetture
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['ONLY_ACTIVE_ARCH'] = 'NO'
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'

      # Fix specifico per Firebase e Xcode 16
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)', 'PB_FIELD_32BIT=1', 'PB_NO_PACKED_STRUCTS=1']
    end
  end
end