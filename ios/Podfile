platform :ios, '15.0'

# Importa le funzioni di Flutter
def flutter_install_ios_engine(ios_application_path = nil)
  path = File.join(ios_application_path, 'Flutter', 'podhelper.rb')
  require path if File.exist?(path)
end

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Carica i plugin (Firestore, ecc.)
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__)) rescue nil
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
    end
  end
end