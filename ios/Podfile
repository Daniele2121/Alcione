platform :ios, '15.0'

podhelper_path = File.join(File.dirname(__FILE__), 'Flutter', 'podhelper.rb')
require podhelper_path

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(__FILE__)
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Configurazioni di base
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'

      # FIX FIRMA DIGITALE: Inserimento Team ID Daniele
      config.build_settings['DEVELOPMENT_TEAM'] = 'MLS38Z78M9'

      # FIX MODULI: Permette l'inclusione di Firebase e altri plugin
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'

      # Assicura che la firma sia coerente tra i vari pod
      config.build_settings['CODE_SIGN_STYLE'] = 'Manual'
    end
  end
end