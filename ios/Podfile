platform :ios, '15.0'

podhelper_path = File.join(File.dirname(__FILE__), 'Flutter', 'podhelper.rb')
require podhelper_path

target 'Runner' do
  use_frameworks! :linkage => :static
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(__FILE__)
end

# UNICO BLOCCO POST_INSTALL (Sistemato per evitare l'errore della Build #35)
post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # 1. Configurazione Firma e Deployment
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['DEVELOPMENT_TEAM'] = 'MLS38Z78M9'
      config.build_settings['PRODUCT_BUNDLE_IDENTIFIER'] = 'it.alcione.scouting'

      # 2. Fix Moduli (cloud_firestore)
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
      config.build_settings['DEFINES_MODULE'] = 'YES'
      config.build_settings['SWIFT_VERSION'] = '5.0'
    end
  end

  # 3. Forza Xcode a trovare le intestazioni dei plugin
  installer.aggregate_targets.each do |target|
    target.xcconfigs.each do |config_name, config|
      config.attributes['HEADER_SEARCH_PATHS'] ||= '$(inherited) $(SRCROOT)/Pods/Headers/Public'
    end
  end
end