platform :ios, '13.0'

# Importante per i moduli Firebase
install! 'cocoapods', :deterministic_uuids => false

# Script semplificato: se c'è la variabile d'ambiente, usa quella (perfetto per GitHub)
# Altrimenti cerca nel file locale (perfetto per il tuo Mac)
def flutter_root
  return ENV['FLUTTER_ROOT'] if ENV['FLUTTER_ROOT']

  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  if File.exist?(generated_xcode_build_settings_path)
    File.foreach(generated_xcode_build_settings_path) do |line|
      matches = line.match(/\AFLUTTER_ROOT=(.*)\z/)
      return matches[1] if matches
    end
  end
  raise "FLUTTER_ROOT non trovato. Esegui flutter pub get."
end

# Carica il podhelper di Flutter
require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper.rb'), flutter_root)

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end
# ... il resto del file (post_install) rimane uguale