platform :ios, '13.0'

import_path = File.join(File.dirname(__FILE__), 'Flutter', 'podhelper.rb')
require import_path

target 'Runner' do
  # FORZA IL LINKAGE STATICO (Risolve il 90% dei problemi Firestore)
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(__FILE__)
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      # Fix per Xcode 15+ trovato sui forum
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= ['$(inherited)', 'PERMISSION_NOTIFICATIONS=1']
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      config.build_settings['FORBID_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
    end
  end
end