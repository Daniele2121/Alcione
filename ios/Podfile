platform :ios, '13.0'

import_path = File.join(File.dirname(__FILE__), 'Flutter', 'podhelper.rb')
require import_path

target 'Runner' do
  # Fondamentale per Firestore
  use_frameworks! :linkage => :static

  flutter_install_all_ios_pods File.dirname(__FILE__)
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      # Questa riga istruisce Xcode su dove cercare gli header dei plugin (Firebase inclusa)
      config.build_settings['HEADER_SEARCH_PATHS'] = '$(inherited) ${PODS_ROOT}/Headers/Public/**'
      config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
    end
  end
end