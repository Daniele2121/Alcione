platform :ios, '15.0'

# --- TUA FUNZIONE FLUTTER_ROOT (MANTENUTA) ---
def flutter_root
  return ENV['FLUTTER_ROOT'] if ENV['FLUTTER_ROOT']
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  if File.exist?(generated_xcode_build_settings_path)
    File.foreach(generated_xcode_build_settings_path) do |line|
      matches = line.match(/\AFLUTTER_ROOT=(.*)\z/)
      return matches[1] if matches
    end
  end
  raise "Flutter SDK non trovato."
end

require File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb')

target 'Runner' do
  use_frameworks!
  use_modular_headers!
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

# --- POST_INSTALL AGGIORNATO PER XCODE 16 ---
post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    # --- FIX DEFINITIVO PER PRIVACY BUNDLES (sqflite, shared_preferences, ecc.) ---
    # Se il target ha una risorsa di privacy, forziamo il corretto posizionamento
    target.build_configurations.each do |config|
      if target.respond_to?(:resource_bundle_targets) && target.resource_bundle_targets.any? { |t| t.name.include?('privacy') }
        config.build_settings['SKIP_INSTALL'] = 'YES'
      end

      # Applichiamo anche il fix specifico se il nome corrisponde ai plugin problematici
      if ['sqflite_darwin', 'shared_preferences_foundation'].include?(target.name)
        config.build_settings['SKIP_INSTALL'] = 'YES'
      end
    end
    # ------------------------------------------------------------------------------

    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['ALWAYS_EMBED_SWIFT_STANDARD_LIBRARIES'] = 'YES'
      config.build_settings['GCC_GENERATE_DEBUGGING_SYMBOLS'] = 'NO'
      config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['CODE_SIGNING_ALLOWED'] = 'NO'
    end
  end
end