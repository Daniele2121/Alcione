platform :ios, '15.0'

# Questa funzione serve a Flutter per trovare la cartella dell'SDK di Flutter
def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "Generated.xcconfig non trovato."
  end
  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/\AFLUTTER_ROOT=(.*)\z/)
    return matches[1] if matches
  end
end

# CORREZIONE: Carica il podhelper direttamente dal flutter_root dell'SDK
flutter_install_all_ios_pods_file = File.join(flutter_root, 'packages', 'flutter_tools', 'bin', 'podhelper.rb')
require flutter_install_all_ios_pods_file

target 'Runner' do
  use_frameworks!
  use_modular_headers!

  # Questa riga installa i plugin (Firestore, ecc.)
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      # Risolve potenziali conflitti di architettura su runner GitHub (Intel/Arm)
      config.build_settings['ONLY_ACTIVE_ARCH'] = 'NO'
    end
  end
end