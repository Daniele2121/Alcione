platform :ios, '13.0'

install! 'cocoapods', :deterministic_uuids => false

def flutter_root
  return ENV['FLUTTER_ROOT'] if ENV['FLUTTER_ROOT']
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  if File.exist?(generated_xcode_build_settings_path)
    File.foreach(generated_xcode_build_settings_path) do |line|
      matches = line.match(/\AFLUTTER_ROOT=(.*)\z/)
      return matches[1] if matches
    end
  end
  raise "FLUTTER_ROOT non trovato."
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper.rb'), flutter_root)

target 'Runner' do
  use_frameworks!
  use_modular_headers!
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    
    # FIX SPECIFICO PER BORINGSSL-GRPC E ERRORE -G
    if target.name == 'BoringSSL-GRPC'
      target.build_configurations.each do |config|
        config.build_settings['OTHER_CFLAGS'] ||= ['$(inherited)']
        config.build_settings['OTHER_CFLAGS'] << '-Wno-unused-function'
        # Rimuove il flag incriminato se presente nelle CFLAGS
        config.build_settings['OTHER_CFLAGS'].delete('-G') if config.build_settings['OTHER_CFLAGS'].is_a?(Array)
      end
    end

    target.build_configurations.each do |config|
      # Forza target iOS 13 per tutti i pod
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      
      # Pulizia globale dei flag del linker
      config.build_settings['OTHER_LDFLAGS'] ||= ['$(inherited)']
      if config.build_settings['OTHER_LDFLAGS'].is_a?(Array)
        config.build_settings['OTHER_LDFLAGS'].delete('-G')
      end

      # Impostazioni simboli di debug richieste dalle nuove versioni di Xcode
      config.build_settings['DEBUG_INFORMATION_FORMAT'] = 'dwarf'
      config.build_settings['STRIP_INSTALLED_PRODUCT'] = 'NO'
    end
  end
end
